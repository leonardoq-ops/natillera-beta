# Local dev only - export these before running:
#   uvicorn main:app --reload
# In Cloud Run, set these as the service's environment variables/secrets instead.

TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Full contents of the downloaded service-account JSON file, as one string
# (not a file path - see google_drive_utils.py).
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-folder-id

# Opaque - filled in once Cowork gives you the real webhook URL. Upload
# flow works fine without it (notify becomes a no-op).
COWORK_WEBHOOK_URL=
ADMIN_EMAIL=leo@natillera.digital

# Shared secret between this service and the Streamlit app - generate any
# long random string and put the same value in both places.
UPLOAD_API_KEY=change-me
