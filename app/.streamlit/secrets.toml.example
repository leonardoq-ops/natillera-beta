# Copy to secrets.toml (gitignored) for local dev, or paste into
# Streamlit Community Cloud "Settings -> Secrets" for the deployed app.

TURSO_DATABASE_URL = "libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN = "your-turso-auth-token"

# Local dev only: if TURSO_DATABASE_URL is unset, db/client.py falls back
# to a local SQLite file (see LOCAL_SQLITE_PATH below).
LOCAL_SQLITE_PATH = "app/local_natillera.db"
